# =====================================================================
# DermaLand — variables de entorno
# Copiar a .env.local (web) y .env (server) según corresponda.
# Nunca commitear .env.local ni .env reales.
# =====================================================================

# ---------- Fase 0–1 (núcleo, requeridas siempre) ---------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# JWT secret (debe coincidir con el de Supabase Auth)
JWT_SECRET=replace-with-supabase-jwt-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PWA_URL=http://localhost:3001
NODE_ENV=development

# Logs
LOG_LEVEL=debug

# ---------- Fase 5 (DGII) — DESHABILITADO hasta tener certificado -----
# Mientras el cliente no entregue cert digital, dejar vacío.
# La flag dgii_enabled por business controla la activación real.
DGII_ENVIRONMENT=cert            # cert | prod
DGII_BASE_URL_CERT=https://ecf.dgii.gov.do/cert
DGII_BASE_URL_PROD=https://ecf.dgii.gov.do
DGII_CERT_BUCKET=certificates
DGII_CERT_ENCRYPTION_KEY=          # 32 bytes hex — generar con: openssl rand -hex 32
DGII_RNC_RD=                       # RNC del negocio piloto

# ---------- Fase 6 (WhatsApp Cloud API) -------------------------------
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=set-a-strong-random-string
META_WA_APP_SECRET=

# ---------- Fase 7 (Agentes IA) ---------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL_TOOLS=gpt-4o-mini
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_PROJECT_ID=

# Anthropic opcional como secondary
ANTHROPIC_API_KEY=

# ---------- Fase 5+ Email transaccional -------------------------------
RESEND_API_KEY=
EMAIL_FROM=DermaLand <noreply@derma.land>

# ---------- Fase 6+ Jobs / queues -------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Fase 10 (Billing SaaS) ------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox        # sandbox | live

CARDNET_MERCHANT_ID=
CARDNET_TERMINAL_ID=
CARDNET_API_KEY=
CARDNET_ENVIRONMENT=test          # test | prod

# ---------- Observabilidad -------------------------------------------
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development

# ---------- Imports / scripts ----------------------------------------
# El catálogo de productos vive en Google Drive para que el cliente lo
# edite en Excel y se sincronice entre máquinas. Ajustar la letra de
# unidad si el clon corre en otro equipo donde Drive monte distinto.
PRODUCT_IMPORT_FILE=G:\Mi unidad\PROYECTO DERMALAND\data\import\productos-inicial.csv

###############################################################################
# DermaLand · variables de entorno
###############################################################################
# Copia este archivo a `.env` y reemplaza placeholders por valores reales.
# `.env` está en `.gitignore` — nunca commitearlo.
# Para compartir secretos entre PCs usa 1Password / Bitwarden, no Drive ni Git.
###############################################################################

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3031
APP_URL=http://localhost:3031
NODE_ENV=development

# Selector del backend de datos:
#   "mock"     → usa src/lib/mock-data/* (default; útil sin Supabase)
#   "supabase" → usa src/server/repositories/supabase/* (requiere keys abajo)
DATA_SOURCE=mock

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo server-side. Bypassea RLS — usar SOLO en server actions / API routes
# con verificación explícita de business_id. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Conexión directa Postgres (Drizzle/Prisma migraciones, scripts CLI)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Auth ──────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
JWT_SECRET=replace-me-with-32-char-random-string
SESSION_COOKIE_NAME=dermaland-session

# ─── DGII e-CF (Fase 5) ────────────────────────────────────────────────────
# Ambiente: "cert" o "prod"
DGII_ENVIRONMENT=cert
DGII_CERTIFICATION_BASE_URL=https://ecf.dgii.gov.do/testecf
DGII_PRODUCTION_BASE_URL=https://ecf.dgii.gov.do/ecf
# Certificado .p12: ruta o key de Supabase Storage privado (bucket "certificates")
DGII_CERTIFICATE_PATH=
DGII_CERTIFICATE_PASSWORD=

# ─── WhatsApp Cloud API (Fase 6) ───────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Webhook recibido en POST /api/whatsapp/webhook

# ─── OpenAI / IA (Fase 7) ──────────────────────────────────────────────────
# Módulo de Proveedores de IA: las API keys se configuran por empresa desde la
# UI (IA > Proveedores de IA) y se guardan CIFRADAS. Requiere la master key:
#   AI_CREDENTIALS_ENCRYPTION_KEY = base64 de 32 bytes  (openssl rand -base64 32)
# Sin ella, no se pueden guardar credenciales de IA. NUNCA la subas a Git.
AI_CREDENTIALS_ENCRYPTION_KEY=
# OPENAI_API_KEY global es OPCIONAL (fallback legado). Si usas la config por-UI
# por empresa, puedes dejarla vacía.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o
# Anthropic como secundario opcional
ANTHROPIC_API_KEY=

# ─── Email transaccional (Fase 5+) ─────────────────────────────────────────
RESEND_API_KEY=

# ─── Observabilidad ────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Storage / Cache ───────────────────────────────────────────────────────
# Upstash Redis (rate limit, cache; Fase 6+)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Secreto para firmar enlaces de PDF compartido (HMAC). Minimo 24 caracteres,
# fuerte y unico. Sin el, la funcion de compartir PDF queda deshabilitada
# (fail-closed, SEC-003). openssl rand -base64 32
DOCUMENT_SHARE_SECRET=

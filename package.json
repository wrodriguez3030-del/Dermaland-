{
  "name": "dermaland",
  "version": "0.0.0",
  "private": true,
  "description": "DermaLand — SaaS multiempresa para farmacia y dermocosmética en RD",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @dermaland/web dev",
    "dev:mobile": "pnpm --filter @dermaland/mobile dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @dermaland/web test:e2e",
    "db:generate": "pnpm --filter @dermaland/db generate",
    "db:migrate": "pnpm --filter @dermaland/db migrate",
    "db:seed": "pnpm --filter @dermaland/db seed",
    "db:studio": "pnpm --filter @dermaland/db studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
